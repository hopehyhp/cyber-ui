{
  "name": "cyber-ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/lib/index.js",
  "module": "./dist/lib/index.js",
  "exports": {
    ".": "./dist/lib/index.js",
    "./components/*": "./dist/lib/components/*",
    "./icons": "./dist/lib/icons/index.js",
    "./styles": "./dist/lib/styles/themes.css",
    "./styles/*": "./dist/lib/styles/*"
  },
  "files": [
    "dist/lib"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "dev": "vite",
    "build": "npm run build:lib && vite build",
    "build:lib": "vite build --config vite.lib.config.js",
    "preview": "vite preview",
    "lint": "eslint . --fix",
    "lint:check": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "vue": "^3.3.4",
    "vue-router": "^4.6.4"
  },
  "peerDependencies": {
    "vue": "^3.3.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^4.6.2",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-vue": "^9.28.0",
    "prettier": "^3.8.4",
    "vite": "^4.5.14"
  }
}
